{
    "compilerOptions": {
        "target": "es2022",
        "lib": ["ES2022"],
        "module": "commonjs",
        "moduleResolution": "node",
        "types": ["node"],
        "strict": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",

    },
    "include": ["src/**/*/.ts"],
    "exclude": ["node_modules"]
}